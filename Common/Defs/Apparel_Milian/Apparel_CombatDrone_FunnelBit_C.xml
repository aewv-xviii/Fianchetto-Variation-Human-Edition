<Defs>

  <!-- typeC -->
  <ThingDef ParentName="Milira_CombatDrone_FunnelBit">
    <defName>Milira_CombatDrone_FunnelBitC</defName>
    <label>Strike drone: Gevurah</label>
    <description>A heavy strike drone equipped with a devastating heavy laser. It excels at breaching armored targets and fortified structures, making it ideal for neutralizing high-threat mechanoids or high-value targets like enemy commanders.\n\nThe Gevurah was originally conceived as a remote beam platform armed with gamma-ray lasers designed to pierce momentum repulsor fields. However, the development logic collapsed after a single, casual remark: "Why don't we just fly a drone inside the shield and shoot the core?" The project was abruptly pivoted, resulting in a drone that simply mounts a standardized heavy laser onto the already-completed chassis.</description>
    <recipeMaker>
      <researchPrerequisites Inherit="false">
        <li>Milira_FloatUnitII</li>
      </researchPrerequisites>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
    </recipeMaker>
    <costList>
      <ComponentIndustrial>32</ComponentIndustrial>
      <ComponentSpacer>4</ComponentSpacer>
      <Plasteel>40</Plasteel>
      <Steel>80</Steel>
      <Chemfuel>35</Chemfuel>
    </costList>
    <graphicData>
      <texPath>Things/Milira_FunnelBit/DroneBox</texPath>
    </graphicData>
    <statBases>
      <WorkToMake>30000</WorkToMake>
      <Mass>3.0</Mass>
      <Flammability>0.4</Flammability>
      <EquipDelay>1.5</EquipDelay>
    </statBases>
    <apparel>
      <tags>
        <li>Milira_CombatDrone_FunnelBit</li>
      </tags>
      <abilities>
        <li>Milira_CombatDrone_FunnelBitB_Ability_C</li>
      </abilities>
    </apparel>
    <comps>
      <li Class="FunnelBit.CompProperties_TurretGun_FunnelBit">
        <layoutDef>Milian_FunnelGizmo_C</layoutDef>
        <turretDef>MiliraTurret_CombatDrone_FunnelBitC</turretDef>
        <angleOffset>-90</angleOffset>
        <autoAttack>true</autoAttack>
        <showDefaultGizmo>false</showDefaultGizmo>

        <autoFire>false</autoFire>
        <focusFire>false</focusFire>
        <autoFireAtFocus>true</autoFireAtFocus>
        <onlyAutoFireWhileDraft>false</onlyAutoFireWhileDraft>
      </li>
      <li Class="FunnelBit.CompProperties_WeaponFunnelGizmo" />

      <li>
        <compClass>CompQuality</compClass>
      </li>
    </comps>
  </ThingDef>

