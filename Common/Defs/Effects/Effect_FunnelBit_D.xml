<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ================================= warmup effecter ================================= -->
  
  <EffecterDef>
    <defName>Milira_FunnelBit_D_warmUp</defName>
    <offsetTowardsTarget>0.8</offsetTowardsTarget>
    <children>
      <!-- flash -->
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <fleckDef>PlainFlash</fleckDef>
        <burstCount>1</burstCount>
        <chancePerTick>1</chancePerTick>
        <chancePeriodTicks>6</chancePeriodTicks>
        <scale>3.0~4.7</scale>
        <color>(1.0,0.2,0.3)</color>
        <spawnLocType>BetweenTouchingCells</spawnLocType>
      </li>
      <!-- spark -->
      <li>
          <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
          <fleckDef>Milira_FunnelBit_B_subProjectile_EnergySpark</fleckDef>
          <burstCount>3~4</burstCount>
          <scale>2.6~4.2</scale>
          <spawnLocType>OnSource</spawnLocType>
        </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <positionRadius>0.37</positionRadius>
        <!-- <positionOffset>(0.55, 0.10)</positionOffset> -->
        <fleckDef>Milira_FunnelBit_B_subProjectile_EnergySpark</fleckDef>
        <chancePerTick>.15</chancePerTick>
        <chancePeriodTicks>15</chancePeriodTicks>
        <!-- <rotation>90</rotation> -->
        <burstCount>1</burstCount>
        <scale>3.0~4.45</scale>
        <color>(0.6,0.8,1.0,1)</color>
        <spawnLocType>BetweenTouchingCells</spawnLocType>
        <!-- <positionLerpFactor>1</positionLerpFactor> -->
        <!-- <positionOffset>(0, 0, 0)</positionOffset> -->
        <!-- <soundDef>ArsenalMilian_Spark</soundDef> -->
      </li>

      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>Milira_FunnelBit_SmokeFast</fleckDef>
        <burstCount>2</burstCount>
        <positionRadius>1.2</positionRadius>
        <scale>2.0~3.0</scale>
        <rotationRate>-30~30</rotationRate>
        <angle>30~40</angle>
        <speed>0.5~0.7</speed>
        <spawnLocType>OnSource</spawnLocType>
      </li>

      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>AirPuff</fleckDef>
        <burstCount>1</burstCount>
        <positionRadius>0.6</positionRadius>
        <scale>1.2</scale>
        <rotationRate>-240~240</rotationRate>
        <angle>-45~45</angle>
        <speed>1.2~1.5</speed>
        <spawnLocType>OnSource</spawnLocType>
      </li>

      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>MicroSparks</fleckDef>
        <burstCount>3</burstCount>
        <positionRadius>0.6</positionRadius>
        <scale>0.8~1.2</scale>
        <rotationRate>-12~12</rotationRate>
        <angle>35~45</angle>
        <speed>1.2</speed>
        <spawnLocType>OnSource</spawnLocType>
      </li>
    </children>
  </EffecterDef>

