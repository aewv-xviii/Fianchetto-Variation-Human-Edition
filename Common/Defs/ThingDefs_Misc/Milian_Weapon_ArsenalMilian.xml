<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="Milian_BaseMakeableGun">
    <defName>Milian_ConductorRod</defName>
    <label>Milian conductor rod</label>
    <description>A drone control interface designed specifically for the Fianchetto.\n\nUsing a quantum entanglement transceiver, it establishes a zero-latency synchronization link with remote units. This rod acts as a high-bandwidth neural bridge, broadcasting the host's internal parallel calculations directly to the swarm to execute complex, unified maneuvers that far exceed standard protocols.\nFor self-defense, it features an integrated low-output particle beam emitter.</description>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>Things/Milira_FunnelBit/ConductorRod_B</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.55</drawSize>
    </graphicData>
    <!-- <uiIconScale>1.0</uiIconScale> -->
    <tradeability>None</tradeability>
    <smeltable>false</smeltable>
    <relicChance>0</relicChance>
    <generateCommonality>1.0</generateCommonality>
    <statBases>
      <MarketValue>500</MarketValue>
      <Mass>1.8</Mass>
      <WorkToMake>28000</WorkToMake>
      <AccuracyTouch>0.90</AccuracyTouch>
      <AccuracyShort>0.95</AccuracyShort>
      <AccuracyMedium>0.95</AccuracyMedium>
      <AccuracyLong>0.95</AccuracyLong>
      <RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Plasteel>30</Plasteel>
      <Steel>70</Steel>
      <ComponentIndustrial>15</ComponentIndustrial>
      <ComponentSpacer>5</ComponentSpacer>
    </costList>
    <recipeMaker>
      <researchPrerequisites Inherit="false">
        <li>Milira_FieldTheory</li>
      </researchPrerequisites>
    </recipeMaker>
    <equippedStatOffsets>
      <!-- <FunnelBit_DroneMobility>0.2</FunnelBit_DroneMobility> -->
      <!-- <FunnelBit_DroneRechargeRate>1.2</FunnelBit_DroneRechargeRate> -->
      <FunnelBit_SubProjectileDamageFactor>0.4</FunnelBit_SubProjectileDamageFactor>
      <FunnelBit_DroneRangeOffset>8</FunnelBit_DroneRangeOffset>
    </equippedStatOffsets>
    <equippedAngleOffset>-35</equippedAngleOffset>
    <weaponTags>
      <li>Milian_ConductorRod</li>
    </weaponTags>
    <weaponClasses>
      <li>RangedHeavy</li>
    </weaponClasses>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <onlyManualCast>false</onlyManualCast>
        <defaultProjectile>MiliraBullet_ConductorRod</defaultProjectile>
        <ai_IsBuildingDestroyer>false</ai_IsBuildingDestroyer>
        <warmupTime>1.5</warmupTime>
        <range>27.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
        <requireLineOfSight>true</requireLineOfSight>
        <soundCast>ArsenalMilian_Shot_DB</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <noiseRadius>2</noiseRadius>
        <muzzleFlashScale>5</muzzleFlashScale>
        <canGoWild>false</canGoWild>
      </li>
    </verbs>
    <tools>
      <li>
        <label>Shaft</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>15</power>
        <cooldownTime>1.6</cooldownTime>
        <armorPenetration>0.2</armorPenetration>
      </li>
    </tools>
    <comps>
    </comps>
  </ThingDef>
  
  <ThingDef ParentName="BaseBullet">
    <defName>MiliraBullet_ConductorRod</defName>
    <label>ion beam</label>
    <projectile>
      <damageDef>Milira_PlasmaBullet_Vulnerable</damageDef>
      <damageAmountBase>8</damageAmountBase>
      <armorPenetrationBase>0.35</armorPenetrationBase>
      <stoppingPower>1.2</stoppingPower>
      <speed>105</speed>
    </projectile>
    <graphicData>
      <texPath>Things/Milira_FunnelBit/FunnelBit_D/FunnelBit_D_particleBeam</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
  </ThingDef>

</Defs>
