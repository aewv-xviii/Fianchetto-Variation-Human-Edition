<Defs>

  <!-- typeB -->
  <ThingDef ParentName="Milira_CombatDrone_FunnelBit">
    <defName>Milira_CombatDrone_FunnelBitB</defName>
    <label>Strike drone: Malkuth</label>
    <description>A remote-controlled "puppet" drone with zero autonomy, serving as the standard armament for the "Fianchetto" model.\n\nStripped of AI cores and heavy batteries, the Malkuth relies on the host's massive parallel processing for combat logic. This allows for erratic, high-G maneuvers driven by force-field propulsion—feats impossible for standard autonomous units to replicate.\nIt is a versatile all-rounder, effective against both swarms and single targets.</description>
    <recipeMaker>
      <researchPrerequisites Inherit="false">
        <li>Milira_FloatUnitII</li>
      </researchPrerequisites>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
    </recipeMaker>
    <costList>
      <ComponentIndustrial>6</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
      <Plasteel>50</Plasteel>
      <Steel>60</Steel>
      <Chemfuel>35</Chemfuel>
    </costList>
    <graphicData>
      <texPath>Things/Milira_FunnelBit/DroneBox</texPath>
    </graphicData>
    <statBases>
      <WorkToMake>30000</WorkToMake>
      <Mass>3.0</Mass>
      <Flammability>0.4</Flammability>
      <EquipDelay>1.5</EquipDelay>
    </statBases>
    <apparel>
      <tags>
        <li>Milira_CombatDrone_FunnelBit</li>
      </tags>
      <abilities>
        <li>Milira_CombatDrone_FunnelBitB_Ability_A</li>
      </abilities>
    </apparel>
    <comps>
      <li Class="FunnelBit.CompProperties_TurretGun_FunnelBit">
        <layoutDef>Milian_FunnelGizmo_B</layoutDef>
        <turretDef>MiliraTurret_CombatDrone_FunnelBitB</turretDef>
        <angleOffset>-90</angleOffset>
        <autoAttack>true</autoAttack>
        <showDefaultGizmo>false</showDefaultGizmo>

        <autoFire>false</autoFire>
        <focusFire>false</focusFire>
        <autoFireAtFocus>true</autoFireAtFocus>
        <onlyAutoFireWhileDraft>false</onlyAutoFireWhileDraft>
      </li>
      <li Class="FunnelBit.CompProperties_WeaponFunnelGizmo" />

      <li>
        <compClass>CompQuality</compClass>
      </li>
    </comps>
  </ThingDef>

