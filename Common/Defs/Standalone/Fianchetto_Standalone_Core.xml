        <hediff>Milira_PlasmaVulnerable</hediff>
        <victimSeverityScalingByInvBodySize>true</victimSeverityScalingByInvBodySize>
        <severityPerDamageDealt>1.0</severityPerDamageDealt>
      </li>
    </additionalHediffs>
  </DamageDef>

</Defs>
