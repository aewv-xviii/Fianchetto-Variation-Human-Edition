<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ========================== Shield ========================== -->
  <EffecterDef>
    <defName>Milira_FunnelBit_ShieldEffecter</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SoundTriggered</subEffecterClass>
        <soundDef>ArsenalMilian_ShieldActive</soundDef>
        <spawnLocType>OnSource</spawnLocType>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>ForceField_Malkuth_GrowingFlash</fleckDef>
        <burstCount>1~1</burstCount>
        <scale>0~0</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <positionRadius>3.5</positionRadius>
        <fleckDef>Milira_FunnelBit_ShieldEnergyCrackle</fleckDef>
        <burstCount>3~5</burstCount>
        <scale>0.6</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>

      <!-- lightning spark -->
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <burstCount>1</burstCount>
        <chancePerTick>.016</chancePerTick>
        <positionOffset>(0, 0, 0)</positionOffset>
        <fleckDef>Milira_FunnelBit_ShieldEnergyCrackle</fleckDef>
        <soundDef>ArsenalMilian_Spark</soundDef>
        <positionRadius>5.7</positionRadius>
        <positionRadiusMin>0</positionRadiusMin>
        <scale>.35</scale>
        <speed>.001</speed>
        <rotation>0</rotation>
        <rotateTowardsTargetCenter>true</rotateTowardsTargetCenter>
        <rotationRate>0</rotationRate>
        <angle>0~0</angle>
        <spawnLocType>OnTarget</spawnLocType>
        <orbitOrigin>true</orbitOrigin>
        <orbitSnapStrength>1.0</orbitSnapStrength>
      </li>

      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <burstCount>1</burstCount>
        <chancePerTick>.05</chancePerTick>
        <chancePeriodTicks>20</chancePeriodTicks>
        <positionOffset>(0, 0, 0)</positionOffset>
        <fleckDef>ForceField_Malkuth_LightningRing</fleckDef>
        <positionRadius>0</positionRadius>
        <positionRadiusMin>0</positionRadiusMin>
        <scale>1</scale>
        <speed>0</speed>
        <rotation>0</rotation>
      </li>

      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <burstCount>1</burstCount>
        <positionOffset>(0, 0, 0)</positionOffset>
        <ticksBetweenMotes>10</ticksBetweenMotes>
        <fleckDef>ForceField_Malkuth_particle</fleckDef>
        <scale>0.8~0.2</scale>
        <positionRadius>6</positionRadius>
        <positionRadiusMin>4.8</positionRadiusMin>
        <speed>-50~50</speed>
        <rotation>0</rotation>
        <rotationRate>-2000~2000</rotationRate>
        <angle>0~0</angle>
        <orbitOrigin>true</orbitOrigin>
        <orbitSpeed>-1~-0.3</orbitSpeed>
        <orbitSnapStrength>1.0</orbitSnapStrength>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <spawnLocType>OnTarget</spawnLocType>
      </li>

      <!-- DarkHighlightRing is Anomaly DLC
      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <burstCount>1</burstCount>
        <positionOffset>(0, 0, 0)</positionOffset>
        <ticksBetweenMotes>40</ticksBetweenMotes>
        <fleckDef>DarkHighlightRing</fleckDef>
        <scale>1.05</scale>
        <positionRadius>0</positionRadius>
        <positionRadiusMin>0</positionRadiusMin>
        <speed>-50~50</speed>
        <rotation>0</rotation>
        <rotationRate>0</rotationRate>
        <angle>0~0</angle>
        <orbitOrigin>true</orbitOrigin>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <spawnLocType>OnTarget</spawnLocType>
      </li>
      -->

    </children>
  </EffecterDef>

