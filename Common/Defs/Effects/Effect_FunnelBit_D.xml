  <!-- slash -->
  <FleckDef ParentName="FleckBase_Thrown">
    <defName>Milira_FunnelBit_D_Slash</defName>
    <graphicData>
      <texPath>Things/Milira_FunnelBit/FunnelBit_D/Effects/Slash</texPath>
      <renderInstanced>true</renderInstanced>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(0.85, 1.5)</drawSize>
    </graphicData>
    <rotateTowardsMoveDirection>true</rotateTowardsMoveDirection>
    <fadeInTime>0.01</fadeInTime>
    <solidTime>0.07</solidTime>
    <fadeOutTime>0.1</fadeOutTime>

    <altitudeLayer>MoteOverhead</altitudeLayer>
  </FleckDef>

