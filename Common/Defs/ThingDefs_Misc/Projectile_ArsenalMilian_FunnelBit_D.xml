      <!-- drone settings -->
      <maxLifeTimeTicks>3000</maxLifeTimeTicks>
      <maxAttackCycles>12</maxAttackCycles>
      <burstShotCount>1</burstShotCount>
      <ticksBetweenBurstShots>10</ticksBetweenBurstShots>

      <!-- Charge time calculation
          finalCharge = (shotsFired * chargeTime) + (flightTicks * chargeLifeFactor)

            Example:
              chargeTime = 60  (1 shot = 1 sec)
              chargeLifeFactor = 0.5  (flight time × 0.5)

            Drone fired 3 shots and flew 10 sec (600 ticks):
              Shot cost   = 3 * 60  = 180 ticks
              Flight cost = 600 * 0.5 = 300 ticks
              Total        = 480 ticks (8 sec)
      -->
      <chargeTime>50</chargeTime>
      <chargeLifeFactor>0.0</chargeLifeFactor>

      <preAttackDelay>8</preAttackDelay>
