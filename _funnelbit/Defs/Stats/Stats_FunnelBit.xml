<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- FunnelBit Drone Stats -->

  <StatDef>
    <defName>FunnelBit_DroneMobility</defName>
    <label>drone mobility</label>
    <description>A multiplier on the movement speed and acceleration of autonomous drones controlled by this person.\n\nHigher values allow drones to move faster and react more quickly.</description>
    <category>PawnCombat</category>
    <workerClass>FunnelBit.StatWorker_DroneHiddenWhenDefault</workerClass>
    <defaultBaseValue>1.0</defaultBaseValue>
    <minValue>0.1</minValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showOnAnimals>false</showOnAnimals>
    <showOnDefaultValue>false</showOnDefaultValue>
    <displayPriorityInCategory>100</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>FunnelBit_DroneRechargeRate</defName>
    <label>drone recharge rate</label>
    <description>A multiplier on the recharge speed of drones. Influences the cooldown time between deployments.\n\nHigher values mean faster cooldowns.</description>
    <category>PawnCombat</category>
    <workerClass>FunnelBit.StatWorker_DroneHiddenWhenDefault</workerClass>
    <defaultBaseValue>1.0</defaultBaseValue>
    <minValue>0.1</minValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showOnAnimals>false</showOnAnimals>
    <showOnDefaultValue>false</showOnDefaultValue>
    <displayPriorityInCategory>101</displayPriorityInCategory>
  </StatDef>


  <StatDef>
    <defName>FunnelBit_SubProjectileDamageFactor</defName>
    <label>drone damage factor</label>
    <description>A multiplier on the damage dealt by projectiles fired from drones.</description>
    <category>PawnCombat</category>
    <workerClass>FunnelBit.StatWorker_DroneHiddenWhenDefault</workerClass>
    <defaultBaseValue>1.0</defaultBaseValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showOnAnimals>false</showOnAnimals>
    <showOnDefaultValue>false</showOnDefaultValue>
    <displayPriorityInCategory>60</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>FunnelBit_DroneRangeOffset</defName>
    <label>drone range offset</label>
    <description>An offset added to the range of autonomous drones controlled by this person.</description>
    <category>PawnCombat</category>
    <workerClass>FunnelBit.StatWorker_DroneHiddenWhenDefault</workerClass>
    <defaultBaseValue>0.0</defaultBaseValue>
    <minValue>-100</minValue>
    <toStringStyle>FloatOne</toStringStyle>
    <showOnAnimals>false</showOnAnimals>
    <showOnDefaultValue>false</showOnDefaultValue>
    <displayPriorityInCategory>102</displayPriorityInCategory>
  </StatDef>



</Defs>
