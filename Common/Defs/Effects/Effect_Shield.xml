  <!-- ============== barGauge mote ============== -->
  <ThingDef ParentName="Mote_FunnelBitProgressBarBase">
    <defName>Mote_ForceField_Malkuth_barGauge</defName>
    <modExtensions>
      <li Class="FunnelBit.MoteProgressBarExtension">
        <barWidth>1.0</barWidth>
        <barHeight>0.16</barHeight>
        <barSpacing>0.252</barSpacing>

        <!-- <offsetX>0.0</offsetX> -->
        <!-- <offsetZ>0.0</offsetZ> -->
        <barOffsetX>0</barOffsetX>
        <barOffsetZ>-0.0</barOffsetZ>
        <!-- <overallBackgroundOffsetX>0.0</overallBackgroundOffsetX> -->
        <!-- <overallBackgroundOffsetZ>0.0</overallBackgroundOffsetZ> -->

        <showBarBackground>false</showBarBackground>

        <defaultFilledColor>(0.92157, 0.24314, 0.32157, 1.0)</defaultFilledColor>

        <showOverallBackground>true</showOverallBackground>
        <overallBackgroundTexturePath>Effects/ForceField_Malkuth_barGaugeBackground</overallBackgroundTexturePath>
        <overallBackgroundWidth>1.8</overallBackgroundWidth>
        <overallBackgroundHeight>1.8</overallBackgroundHeight>
